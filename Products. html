                        <span class="spec">5G</span>
                    </div>
                    <div class="product-footer">
                        <div class="price">7,999 ر.س</div>
                        <button class="btn-add">أضف للسلة</button>
                    </div>
                </div>
            </div>

            <!-- المنتج 2 -->
            <div class="product-card">
                <div class="product-image">📱</div>
                <div class="product-info">
                    <div class="product-name">Samsung Galaxy S24 Ultra</div>
                    <div class="product-description">تصوير احترافي مع تقنيات الذكاء الاصطناعي</div>
                    <div class="product-specs">
                        <span class="spec">6.8 بوصة</span>
                        <span class="spec">256GB</span>
                        <span class="spec">5G</span>
                    </div>
                    <div class="product-footer">
                        <div class="price">6,999 ر.س</div>
                        <button class="btn-add">أضف للسلة</button>
                    </div>
                </div>
            </div>

            <!-- المنتج 3 -->
            <div class="product-card">
                <div class="product-image">📱</div>
                <div class="product-info">
                    <div class="product-name">Google Pixel 8 Pro</div>
                    <div class="product-description">أفضل الكاميرات مع معالج Tensor</div>
                    <div class="product-specs">
                        <span class="spec">6.7 بوصة</span>
                        <span class="spec">256GB</span>
                        <span class="spec">5G</span>
                    </div>
                    <div class="product-footer">
                        <div class="price">5,499 ر.س</div>
                        <button class="btn-add">أضف للسلة</button>
                    </div>
                </div>
            </div>

            <!-- المنتج 4 -->
            <div class="product-card">
                <div class="product-image">📱</div>
                <div class="product-info">
                    <div class="product-name">OnePlus 12</div>
                    <div class="product-description">أداء عالي وشحن سريع جداً</div>
                    <div class="product-specs">
                        <span class="spec">6.7 بوصة</span>
                        <span class="spec">512GB</span>
                        <span class="spec">5G</span>
                    </div>
                    <div class="product-footer">
                        <div class="price">4,999 ر.س</div>
                        <button class="btn-add">أضف للسلة</button>
                    </div>
                </div>
            </div>

            <!-- المنتج 5 -->
            <div class="product-card">
                <div class="product-image">📱</div>
                <div class="product-info">
                    <div class="product-name">iPhone 15</div>
                    <div class="product-description">الخيار الاقتصادي من Apple</div>
                    <div class="product-specs">
                        <span class="spec">6.1 بوصة</span>
                        <span class="spec">128GB</span>
                        <span class="spec">5G</span>
                    </div>
                    <div class="product-footer">
                        <div class="price">4,499 ر.س</div>
                        <button class="btn-add">أضف للسلة</button>
                    </div>
                </div>
            </div>

            <!-- المنتج 6 -->
            <div class="product-card">
                <div class="product-image">📱</div>
                <div class="product-info">
                    <div class="product-name">Samsung Galaxy A54</div>
                    <div class="product-description">أداء متميز بسعر معقول</div>
                    <div class="product-specs">
                        <span class="spec">6.4 بوصة</span>
                        <span class="spec">128GB</span>
                        <span class="spec">5G</span>
                    </div>
                    <div class="product-footer">
                        <div class="price">2,999 ر.س</div>
                        <button class="btn-add">أضف للسلة</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer>
        <p>&copy; 2024 متجر الهواتف الفاخرة - جميع الحقوق محفوظة</p>
        <p>نوفر أفضل الهواتف الذكية بأسعار تنافسية</p>
    </footer>

    <script>
        // تفعيل أزرار التصفية
        const filterButtons = document.querySelectorAll('.filters button');
        filterButtons.forEach(button => {
            button.addEventListener('click', () => {
                filterButtons.forEach(btn => btn.classList.remove('active'));
                button.classList.add('active');
            });
        });

        // تفعيل أزرار الإضافة للسلة
        const addButtons = document.querySelectorAll('.btn-add');
        addButtons.forEach(button => {
            button.addEventListener('click', (e) => {
                const productName = e.target.closest('.product-card').querySelector('.product-name').textContent;
                alert(`تم إضافة ${productName} إلى السلة!`);
            });
        });
    </script>
</body>
</html>